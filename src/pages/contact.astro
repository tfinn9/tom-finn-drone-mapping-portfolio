---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Contact — Tom Finn Drone Mapping Portfolio';
const description = 'Contact Tom Finn for drone mapping, field operations, and agricultural technology opportunities.';

const contact = {
  email: 'tom@example.com',
  linkedin: 'https://www.linkedin.com/in/tomfinn',
  github: 'https://github.com/tomfinn',
  resume: '/resume.pdf',
};
---

<Layout title={title} description={description}>
  <Header />
  <main id="main">
    <section class="section">
      <div class="container">
        <div style="max-width: 720px;">
          <p class="text-label fade-in">Contact</p>
          <h1 class="text-title fade-in" style="transition-delay: 50ms; margin-block: 1rem 1.5rem;">
            Let’s talk about field operations
          </h1>
          <p class="text-body fade-in" style="transition-delay: 100ms;">
            I am currently looking for a Drone Mapping Specialist role where I can combine fieldwork, mapping, and technology to support agricultural operations. Reach out by email or LinkedIn.
          </p>
        </div>

        <div class="contact-grid" style="margin-block: 3rem;">
          <a href={`mailto:${contact.email}`} class="contact-card fade-in" style="transition-delay: 150ms;">
            <span class="contact-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="M22 7l-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </span>
            <span class="contact-card-title">Email</span>
            <span class="contact-card-value">{contact.email}</span>
          </a>

          <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="contact-card fade-in" style="transition-delay: 200ms;">
            <span class="contact-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </span>
            <span class="contact-card-title">LinkedIn</span>
            <span class="contact-card-value">linkedin.com/in/tomfinn</span>
          </a>

          <a href={contact.github} target="_blank" rel="noopener noreferrer" class="contact-card fade-in" style="transition-delay: 250ms;">
            <span class="contact-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
            </span>
            <span class="contact-card-title">GitHub</span>
            <span class="contact-card-value">github.com/tomfinn</span>
          </a>

          <a href={contact.resume} download class="contact-card fade-in" style="transition-delay: 300ms;">
            <span class="contact-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
            </span>
            <span class="contact-card-title">Download Resume</span>
            <span class="contact-card-value">PDF, ~120 KB</span>
          </a>
        </div>

        <hr class="divider" />

        <section class="qr-card fade-in" aria-labelledby="qr-heading">
          <canvas id="qr-canvas" class="qr-canvas" aria-label="QR code linking to this website"></canvas>
          <div>
            <h2 id="qr-heading" class="text-headline" style="margin-bottom: 0.5rem;">Link from your resume</h2>
            <p class="text-body" style="max-width: 520px;">
              Scan this QR code to open this portfolio directly from a printed resume or business card. The code is generated from the current page URL.
            </p>
          </div>
        </section>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline src="https://unpkg.com/qrious@4.0.2/dist/qrious.min.js"></script>
  <script is:inline>
    (function () {
      const observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.fade-in').forEach(function (el) { observer.observe(el); });

      const canvas = document.getElementById('qr-canvas');
      if (!canvas || typeof window.QRious === 'undefined') return;

      new window.QRious({
        element: canvas,
        value: window.location.href,
        size: 240,
        level: 'M',
        background: '#ffffff',
        foreground: '#1a2e1f',
        padding: 8,
      });
    })();
  </script>
</Layout>
