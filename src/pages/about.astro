---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'About — Tom Finn Drone Mapping Portfolio';
const description = 'Professional biography of Tom Finn, a drone mapping specialist with experience in customer success, business ownership, and agricultural technology.';
---

<Layout title={title} description={description}>
  <Header />
  <main id="main">
    <section class="section">
      <div class="container">
        <div style="max-width: 760px;">
          <p class="text-label fade-in">About</p>
          <h1 class="text-title fade-in" style="transition-delay: 50ms; margin-block: 1rem 1.5rem;">
            Tom Finn
          </h1>
          <p class="text-body fade-in" style="transition-delay: 100ms; font-size: 1.15rem;">
            I am a drone mapping specialist with a background in customer success, business ownership, and technology. I am motivated by practical problem solving and by helping rural businesses make better decisions from accurate field data.
          </p>
        </div>
      </div>
    </section>

    <section class="section section-alt" aria-labelledby="background-heading">
      <div class="container">
        <h2 id="background-heading" class="text-headline fade-in" style="margin-bottom: 2.5rem;">Professional background</h2>

        <div style="display: grid; gap: 1.5rem;">
          <article class="card fade-in" style="transition-delay: 50ms;">
            <div class="card-body">
              <h3 class="text-headline" style="font-size: 1.1rem; margin-bottom: 0.75rem;">Customer Success</h3>
              <p class="text-body">
                Years of working directly with customers taught me that the best technology is the one people actually use. I translate complex technical workflows into clear outcomes, onboard teams, and proactively resolve blockers before they become problems.
              </p>
            </div>
          </article>

          <article class="card fade-in" style="transition-delay: 100ms;">
            <div class="card-body">
              <h3 class="text-headline" style="font-size: 1.1rem; margin-bottom: 0.75rem;">Business ownership</h3>
              <p class="text-body">
                Running my own business developed my judgment around scope, cost, delivery, and communication. I am comfortable owning outcomes end to end—from the first client conversation through to the final deliverable and follow-up.
              </p>
            </div>
          </article>

          <article class="card fade-in" style="transition-delay: 150ms;">
            <div class="card-body">
              <h3 class="text-headline" style="font-size: 1.1rem; margin-bottom: 0.75rem;">Drone mapping</h3>
              <p class="text-body">
                I plan, fly, and process photogrammetry missions for agriculture and rural operations. I work with a DJI Mini 3 and WebODM, producing orthomosaics, DSMs, and point clouds that support grazing, irrigation, and land management decisions.
              </p>
            </div>
          </article>

          <article class="card fade-in" style="transition-delay: 200ms;">
            <div class="card-body">
              <h3 class="text-headline" style="font-size: 1.1rem; margin-bottom: 0.75rem;">Technology</h3>
              <p class="text-body">
                I am comfortable with modern web tools, geospatial software, APIs, and automation. I enjoy building small systems that make repeatable work faster and more reliable, whether that is a flight checklist or a data processing pipeline.
              </p>
            </div>
          </article>

          <article class="card fade-in" style="transition-delay: 250ms;">
            <div class="card-body">
              <h3 class="text-headline" style="font-size: 1.1rem; margin-bottom: 0.75rem;">Agricultural technology</h3>
              <p class="text-body">
                I am excited by the role precision data plays in sustainable farming. Halter’s work in virtual fencing and herd management aligns with my interest in combining hardware, software, and field operations to improve productivity.
              </p>
            </div>
          </article>

          <article class="card fade-in" style="transition-delay: 300ms;">
            <div class="card-body">
              <h3 class="text-headline" style="font-size: 1.1rem; margin-bottom: 0.75rem;">Problem solving</h3>
              <p class="text-body">
                I break ambiguous challenges into steps, test assumptions quickly, and communicate progress clearly. In the field this means safe, efficient missions; in a team it means dependable delivery and honest status updates.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    // @ts-nocheck
    (function () {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    })();
  </script>
</Layout>
