---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects.js';
import { withBase } from '../../utils/paths.js';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const title = `${project.title} — Tom Finn Drone Mapping Portfolio`;
---

<Layout title={title}>
  <Header />
  <main id="main">
    <article class="section">
      <div class="container">
        <p class="text-label fade-in">{project.location}{project.date ? ` · ${project.date}` : ''}</p>
        <h1 class="text-title fade-in" style="transition-delay: 50ms; margin-block: 0.75rem 1.5rem;">
          {project.title}
        </h1>
        <p class="text-body fade-in" style="transition-delay: 100ms; max-width: 800px; font-size: 1.1rem;">
          {project.objective}
        </p>

        <div class="project-thumb fade-in" style="transition-delay: 150ms; margin-block: 3rem; border-radius: var(--radius-lg);" data-lightbox={withBase(project.fullResolution || project.preview)} data-alt={`Full resolution orthomosaic for ${project.title}`} role="button" tabindex="0" aria-label={`Open full resolution orthomosaic for ${project.title}`}>
          <img src={withBase(project.preview)} alt={`Orthomosaic preview for ${project.title}`} loading="eager" />
        </div>

        <div class="card fade-in" style="transition-delay: 200ms;">
          <div class="card-body">
            <h2 class="text-headline" style="margin-bottom: 1rem;">Mission details</h2>
            <table class="meta-table">
              <tbody>
                <tr>
                  <th>Location</th>
                  <td>{project.location}</td>
                </tr>
                {project.date && (
                <tr>
                  <th>Survey date</th>
                  <td>{project.date}</td>
                </tr>
                )}
                <tr>
                  <th>Mission objective</th>
                  <td>{project.objective}</td>
                </tr>
                <tr>
                  <th>Drone used</th>
                  <td>{project.drone}</td>
                </tr>
                <tr>
                  <th>Software used</th>
                  <td>{project.software}</td>
                </tr>
                <tr>
                  <th>Flight altitude</th>
                  <td>{project.flightAltitude}</td>
                </tr>
                <tr>
                  <th>Number of photos</th>
                  <td>{project.numberOfPhotos.toLocaleString()}</td>
                </tr>
                <tr>
                  <th>Mission duration</th>
                  <td>{project.missionDuration}</td>
                </tr>
                <tr>
                  <th>Output resolution</th>
                  <td>{project.outputResolution}</td>
                </tr>
                <tr>
                  <th>Weather conditions</th>
                  <td>{project.weatherConditions}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="card fade-in" style="transition-delay: 250ms; margin-top: 1.5rem;">
          <div class="card-body">
            <h2 class="text-headline" style="margin-bottom: 1rem;">Processing workflow</h2>
            <p class="text-body">{project.processingWorkflow}</p>
          </div>
        </div>

        <div class="card fade-in" style="transition-delay: 300ms; margin-top: 1.5rem;">
          <div class="card-body">
            <h2 class="text-headline" style="margin-bottom: 1rem;">Challenges</h2>
            <p class="text-body">{project.challenges}</p>
          </div>
        </div>

        <div class="card fade-in" style="transition-delay: 350ms; margin-top: 1.5rem;">
          <div class="card-body">
            <h2 class="text-headline" style="margin-bottom: 1rem;">Lessons learned</h2>
            <p class="text-body">{project.lessonsLearned}</p>
          </div>
        </div>

        <hr class="divider" />

        <section class="fade-in" aria-labelledby="report-heading">
          <div class="card">
            <div class="card-body" style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;">
              <div>
                <h2 id="report-heading" class="text-headline" style="margin-bottom: 0.35rem;">Quality report</h2>
                <p class="text-body" style="font-size: 0.95rem;">Download the WebODM processing report for this survey.</p>
              </div>
              <a href={withBase(project.report)} download class="btn btn-primary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Download PDF
              </a>
            </div>
          </div>
        </section>

        <div style="margin-top: 2.5rem;">
          <a href={withBase('/projects')} class="btn btn-secondary">← Back to projects</a>
        </div>
      </div>
    </article>
  </main>
  <Footer />

  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Full resolution orthomosaic">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
    <img src="" alt="" id="lightbox-img" />
  </div>

  <script>
    // @ts-nocheck
    (function () {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

      const lightbox = document.getElementById('lightbox');
      const lightboxImg = document.getElementById('lightbox-img');
      const closeBtn = lightbox?.querySelector('.lightbox-close');
      if (lightbox && lightboxImg && closeBtn) {
        function open(src, alt) {
          lightboxImg.src = src;
          lightboxImg.alt = alt;
          lightbox.classList.add('is-open');
          document.body.style.overflow = 'hidden';
          closeBtn.focus();
        }
        function close() {
          lightbox.classList.remove('is-open');
          lightboxImg.src = '';
          lightboxImg.alt = '';
          document.body.style.overflow = '';
        }
        const thumb = document.querySelector('[data-lightbox]');
        if (thumb) {
          thumb.addEventListener('click', () => open(thumb.dataset.lightbox, thumb.dataset.alt || ''));
          thumb.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              open(thumb.dataset.lightbox, thumb.dataset.alt || '');
            }
          });
        }
        closeBtn.addEventListener('click', close);
        lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && lightbox.classList.contains('is-open')) close(); });
      }
    })();
  </script>
</Layout>
