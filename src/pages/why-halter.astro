---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/paths.js';

const title = 'Why Halter? — Tom Finn Drone Mapping Portfolio';
const description = 'Why Tom Finn is excited about drone mapping and agricultural technology at Halter.';
---

<Layout title={title} description={description}>
  <Header />
  <main id="main">
    <section class="section">
      <div class="container">
        <div style="max-width: 720px;">
          <p class="text-label fade-in">Why Halter?</p>
          <h1 class="text-title fade-in" style="transition-delay: 50ms; margin-block: 1rem 1.5rem;">
            Why I’m excited about this role
          </h1>

          <p class="text-body fade-in" style="transition-delay: 100ms; font-size: 1.1rem; margin-bottom: 1.5rem;">
            Agriculture is where some of the most tangible problems in New Zealand are solved. I have spent time around rural and coastal communities and have seen how much farmers and growers rely on accurate information to make decisions about land, water and livestock. I am drawn to the sector because the work is outdoors, practical and directly tied to outcomes that matter; healthier land, more efficient operations and stronger rural businesses.
          </p>
          <p class="text-body fade-in" style="transition-delay: 150ms; font-size: 1.1rem; margin-bottom: 1.5rem;">
          I was a member of my local Young Farmers for many years until I aged-out, and even served as Secretary for the club and our Tasman Region Young Farmers as well.  
          </p>
          <p class="text-body fade-in" style="transition-delay: 150ms; font-size: 1.1rem; margin-bottom: 1.5rem;">
            Drone mapping appeals to me because it sits at the intersection of fieldwork and technology. I enjoy planning a mission, capturing clean imagery and turning raw data into something useful. There is something satisfying about seeing a scatter of photos become a sharp, measurable map, and I like that the work is hands-on while also requiring attention to detail and systematic problem-solving.
          </p>

          <p class="text-body fade-in" style="transition-delay: 200ms; font-size: 1.1rem; margin-bottom: 1.5rem;">
            The Drone Mapping Specialist role at Halter brings these two interests together. It offers the chance to work in the field, support customers with practical data, and contribute to a company building technology specifically for agriculture, including virtual fencing and precision grazing. That combination of real farms, real problems, and the tools to solve them is exactly the career direction I want to take.
          </p>

          <div class="hero-actions fade-in" style="transition-delay: 250ms; margin-top: 2.5rem;">
            <a href={withBase('/')} class="btn btn-secondary">← Back to home</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    // @ts-nocheck
    (function () {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    })();
  </script>
</Layout>
