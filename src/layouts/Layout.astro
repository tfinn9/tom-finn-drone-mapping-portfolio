---
import '../styles/global.css';
import { withBase } from '../utils/paths.js';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
}

const {
  title = 'Tom Finn — Drone Mapping & Field Operations',
  description = 'Portfolio of orthomosaic mapping projects by Tom Finn, a Drone Mapping Specialist using DJI Mini 3 and WebODM for agriculture and field operations.',
  image = '/og-image.svg',
  pathname = Astro.url.pathname,
} = Astro.props;

const canonical = new URL(pathname, Astro.site).toString();
const ogImage = new URL(withBase(image), Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en-NZ">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Tom Finn" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="apple-touch-icon" href={withBase('/favicon.svg')} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_NZ" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#f7faf7" />
    <meta name="color-scheme" content="light" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>
