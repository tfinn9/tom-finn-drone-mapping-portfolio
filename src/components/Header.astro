---
import { withBase } from '../utils/paths.js';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="container">
    <a href={withBase('/')} class="logo" aria-label="Tom Finn home">
      <svg class="logo-mark" viewBox="0 0 100 100" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="50" cy="50" r="16"/>
        <path d="M20 24h60M20 76h60M34 24v12M66 24v12M34 64v12M66 64v12"/>
        <path d="M28 36L20 24l-8 12M72 36l8-12 8 12M28 64l-8 12-8-12M72 64l8 12 8-12" stroke-width="4.5"/>
      </svg>
      <span>Tom Finn</span>
    </a>

    <nav aria-label="Primary">
      <button class="mobile-menu-toggle" aria-expanded="false" aria-controls="nav-list" aria-label="Toggle menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line class="menu-icon-line" x1="4" y1="6" x2="20" y2="6"/>
          <line class="menu-icon-line" x1="4" y1="12" x2="20" y2="12"/>
          <line class="menu-icon-line" x1="4" y1="18" x2="20" y2="18"/>
        </svg>
      </button>
      <ul class="nav-list" id="nav-list">
        {navItems.map((item) => {
          const itemPath = withBase(item.href);
          return (
            <li>
              <a
                href={itemPath}
                class="nav-link"
                aria-current={pathname === itemPath || pathname.startsWith(itemPath + '/') ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<script>
  (function () {
    const toggle = document.querySelector('.mobile-menu-toggle');
    const navList = document.getElementById('nav-list');
    if (!toggle || !navList) return;

    toggle.addEventListener('click', () => {
      const isOpen = navList.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    navList.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        navList.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>
